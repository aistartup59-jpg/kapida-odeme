NODE_ENV=test
PORT=3001

# Points at the dedicated postgres-test service in docker-compose.yml — never the dev DB.
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=kapida
DATABASE_PASSWORD=kapida
DATABASE_NAME=kapida_test

# Required. No default — the application refuses to start without it.
JWT_SECRET=test-jwt-secret-change-me

# Required. No default — the application refuses to start without it.
CREDENTIAL_ENCRYPTION_SECRET=test-credential-encryption-secret-change-me
